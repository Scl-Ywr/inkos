# ─── InkOS Studio 自部署环境变量配置 ───
# 复制为 .env 后编辑: cp .env.docker .env

# 宿主机端口映射（默认 8080）
INKOS_PORT=8080

# LLM 服务商 (openai / anthropic / custom)
INKOS_LLM_PROVIDER=openai

# API 地址（OpenAI 兼容接口）
INKOS_LLM_BASE_URL=https://api.openai.com/v1

# API 密钥（必填）
INKOS_LLM_API_KEY=sk-your-key-here

# 模型名称
INKOS_LLM_MODEL=gpt-4o
